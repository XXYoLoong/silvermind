NODE_ENV=development
HOST=127.0.0.1
PORT=3001
SILVERMIND_DATA_DIR=./server/data

# Frontend
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:3001

# Server-side model keys. Fill these only in local/private environments.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TEXT_MODEL=deepseek-v4-flash
DEEPSEEK_TEXT_TIMEOUT_MS=12000

DASHSCOPE_API_KEY=
QWEN_API_KEY=
DASHSCOPE_REGION_BASE_URL=https://dashscope.aliyuncs.com
QWEN_IMAGE_MODEL=wan2.6-t2i
QWEN_IMAGE_SIZE=1280*1280
